# ── Server ──────────────────────────────────────
PORT=3001

# ── Finnhub (NEVER commit the real key) ─────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Auth ────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=change-this-too

# ── Gmail SMTP (App Password) ────────────────────
# 1. Enable 2FA on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a password for "Mail"
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Google OAuth ─────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable "Google+ API" or "People API"
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Cloudflare Turnstile ─────────────────────────
# 1. Go to https://dash.cloudflare.com → Turnstile → Add widget
# 2. Copy the secret key (backend) and site key (frontend)
TURNSTILE_SECRET=your_turnstile_secret_key

# ── Frontend (Vite) ──────────────────────────────
# Copy to .env (same file is fine — Vite reads VITE_ prefixed vars)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Optional — browser error monitoring (leave unset to disable, see src/sentry.js)
VITE_SENTRY_DSN=

# Optional — product analytics (leave unset to disable, see src/analytics.js)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Paddle (checkout) ────────────────────────────
# Leave unset to disable checkout entirely (see server/services/paddle.js,
# src/paddle.js). Sandbox first — switch PADDLE_ENV to "production" only
# once you've tested a full purchase in sandbox.
# 1. Sign up at https://sandbox-vendors.paddle.com (sandbox) or https://vendors.paddle.com (live)
# 2. Catalog → Products → create "Capital Flow Premium" and "Capital Flow Elite",
#    each with a one-time Price ($14.90 / $29.90) → copy each Price's ID (pri_...)
# 3. Developer Tools → Authentication → create an API key → PADDLE_API_KEY
# 4. Developer Tools → Notifications → create a webhook pointed at
#    https://yourdomain.com/api/webhooks/paddle, subscribed to "transaction.completed"
#    → copy its signing secret → PADDLE_WEBHOOK_SECRET
# 5. Developer Tools → Authentication → Client-side tokens → create one → VITE_PADDLE_CLIENT_TOKEN
PADDLE_ENV=sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PREMIUM_PRICE_ID=
PADDLE_ELITE_PRICE_ID=
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENV=sandbox

# ── Turso (cloud SQLite for production / Koyeb) ──
# Free tier — no credit card required.
# 1. Sign up at https://turso.tech
# 2. turso db create capital-flow
# 3. turso db show capital-flow --url        → TURSO_DB_URL
# 4. turso db tokens create capital-flow     → TURSO_AUTH_TOKEN
# Leave both unset for local dev (uses file:./data/users.db instead).
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# ── URLs ─────────────────────────────────────────
# Dev: Vite dev server URL (Google OAuth redirects here after login)
FRONTEND_URL=http://localhost:5173
# Prod: your real domain
# FRONTEND_URL=https://yourdomain.com
