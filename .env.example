# ── Server ──────────────────────────────────────
PORT=3001

# ── Finnhub (NEVER commit the real key) ─────────
FINNHUB_API_KEY=your_finnhub_key_here

# ── Auth ────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
SESSION_SECRET=change-this-too

# ── Resend (transactional email — OTP, welcome, admin signup alerts) ──
# 1. Sign up free at https://resend.com
# 2. Domains → Add Domain → add the DNS records it gives you at your
#    registrar → wait for it to show "Verified"
# 3. API Keys → Create API Key (Sending access is enough)
# 4. RESEND_FROM_EMAIL must be an address at that verified domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Capital Flow <noreply@yourdomain.com>

# ── Gmail SMTP (App Password) — used ONLY for the daily DB backup email ──
# 1. Enable 2FA on your Google account
# 2. Go to Google Account → Security → App Passwords
# 3. Generate a password for "Mail"
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Google OAuth ─────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable "Google+ API" or "People API"
# 3. Credentials → Create OAuth 2.0 Client ID (Web application)
# 4. Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── Cloudflare Turnstile ─────────────────────────
# 1. Go to https://dash.cloudflare.com → Turnstile → Add widget
# 2. Copy the secret key (backend) and site key (frontend)
TURNSTILE_SECRET=your_turnstile_secret_key

# ── Frontend (Vite) ──────────────────────────────
# Copy to .env (same file is fine — Vite reads VITE_ prefixed vars)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Optional — browser error monitoring (leave unset to disable, see src/sentry.js)
VITE_SENTRY_DSN=

# Optional — product analytics (leave unset to disable, see src/analytics.js)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Whop (checkout) ──────────────────────────────
# Leave WHOP_API_KEY unset to disable checkout entirely (see
# server/services/whop.js). Checkout is a full-page redirect to Whop's
# hosted page — no frontend/VITE_ key needed.
# 1. Sign up / log in at https://whop.com and create (or open) your business
# 2. Products → Create product → "Capital Flow Premium" / "Capital Flow
#    Elite", Paid access → One-time → $14.90 / $29.90 → Save
# 3. Developer → Company API keys → Create (role: Admin) → WHOP_API_KEY
# 4. Look up each product's plan id: GET
#    https://api.whop.com/api/v2/products/{prod_id} with an Authorization:
#    Bearer header → the "plans" array → WHOP_PREMIUM_PLAN_ID / WHOP_ELITE_PLAN_ID
# 5. Developer → Webhooks → Create webhook → URL
#    https://yourdomain.com/api/webhooks/whop, event "payment_succeeded"
#    → copy its secret → WHOP_WEBHOOK_SECRET
WHOP_API_KEY=
WHOP_WEBHOOK_SECRET=
WHOP_PREMIUM_PLAN_ID=
WHOP_ELITE_PLAN_ID=

# ── Turso (cloud SQLite for production / Koyeb) ──
# Free tier — no credit card required.
# 1. Sign up at https://turso.tech
# 2. turso db create capital-flow
# 3. turso db show capital-flow --url        → TURSO_DB_URL
# 4. turso db tokens create capital-flow     → TURSO_AUTH_TOKEN
# Leave both unset for local dev (uses file:./data/users.db instead).
TURSO_DB_URL=
TURSO_AUTH_TOKEN=

# ── URLs ─────────────────────────────────────────
# Dev: Vite dev server URL (Google OAuth redirects here after login)
FRONTEND_URL=http://localhost:5173
# Prod: your real domain
# FRONTEND_URL=https://yourdomain.com
